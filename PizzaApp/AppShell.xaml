<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PizzaApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PizzaApp"
    Title="PizzaApp"
    BackgroundColor="White"
    FlyoutBackgroundColor="#070252"
    >
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="15">
                <Label Text="{Binding Title}"
                       FontSize="15"
                       TextColor="White"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem Title="Order" >
        
        <ShellContent

            Title="Order"
            ContentTemplate="{DataTemplate local:MainPage}"
               

            />
        
    </FlyoutItem>

    <FlyoutItem Title="Admin" >
        <ShellContent
            Title="Admin"
            ContentTemplate="{DataTemplate local:AdminPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Cart" >
        <ShellContent
            Title="Cart"
            ContentTemplate="{DataTemplate local:CartPage}" />
    </FlyoutItem>

</Shell>
